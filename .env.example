# ── BMV Menüdienst – Konfigurationsvorlage ─────────────────────
# Kopieren nach .env und alle Werte ausfüllen

APP_ENV=local
APP_DEBUG=false

# ── Admin Panel ─────────────────────────────────────────────────
# Pflichtfeld – Zugriff ohne Wert wird mit 503 verweigert
# Empfehlung: openssl rand -hex 32
BMV_ADMIN_KEY=

# ── Mail ────────────────────────────────────────────────────────
MAIL_DRIVER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_ENCRYPTION=null
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=info@bmv-kantinen.de
MAIL_FROM_NAME="BMV Kantinen"
MAIL_TO=info@bmv-kantinen.de

# ── APIs (optional) ─────────────────────────────────────────────
PEXELS_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
