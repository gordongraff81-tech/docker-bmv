# ════════════════════ SPEISEPLAN DOCKER COMPOSE ════════════════════
# Digitales Menümanagement mit Admin-Panel, Kundenansicht & Echtzeit-Sync
# ════════════════════════════════════════════════════════════════════

# Umgebungsvariablen für Production/Development

# ════════════════════ DATABASE ════════════════════
DB_USER=speiseplan
DB_PASSWORD=your_secure_password_here_change_in_production
DB_NAME=speiseplan

# ════════════════════ JWT SECURITY ════════════════════
JWT_SECRET=your_jwt_secret_key_change_in_production_1234567890

# ════════════════════ API SETTINGS ════════════════════
NODE_ENV=production
API_PORT=3000

# ════════════════════ CORS SETTINGS ════════════════════
CORS_ORIGIN=http://localhost:8080,http://localhost:8081,http://localhost:8082,http://localhost:3000

# ════════════════════ FRONTEND ════════════════════
REACT_APP_API_URL=http://localhost:3000
REACT_APP_SOCKET_URL=http://localhost:3000
