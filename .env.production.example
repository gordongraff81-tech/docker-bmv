# ── BMV Menüdienst – Produktionskonfiguration ──────────────────
# Kopieren nach .env auf dem Produktionsserver

APP_ENV=production
APP_DEBUG=false

# ── Admin Panel ─────────────────────────────────────────────────
# openssl rand -hex 32
BMV_ADMIN_KEY=

# ── Mail (Greatnet SMTP) ────────────────────────────────────────
MAIL_DRIVER=smtp
MAIL_HOST=mail.bmv-kantinen.de
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=info@bmv-kantinen.de
MAIL_PASSWORD=
MAIL_FROM=info@bmv-kantinen.de
MAIL_FROM_NAME="BMV Menüdienst"
MAIL_TO=info@bmv-kantinen.de

# ── APIs (optional) ─────────────────────────────────────────────
PEXELS_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
